---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  canonicalURL?: string;
  ogImage?: string;
  ogType?: string;
  keywords?: string;
}

const {
  title = 'Shreesh Kulkarni — Software Engineer',
  description =
    'Shreesh Kulkarni — Software Engineer & AI builder. MSCS at Northeastern (4.0 GPA). LangChain, RAG, React, FastAPI. Open to full-time roles.',
  ogImage = '/og.png',
  ogType = 'website',
  keywords = 'Shreesh Kulkarni, Software Engineer, AI Engineer, Full-Stack Developer, Full-Stack Engineer, LangChain, RAG Pipelines, Model Context Protocol, React, Next.js, FastAPI, PostgreSQL, AWS, Cloud-native Microservices, Northeastern University, MSCS',
} = Astro.props;

const siteURL = 'https://shreeshkulkarni.dev';
const canonicalURL = Astro.props.canonicalURL ?? new URL(Astro.url.pathname, siteURL).href;
const ogImageURL = new URL(ogImage, siteURL).href;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <!-- ─── Essentials ─────────────────────────────────────── -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="Shreesh Kulkarni" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="theme-color" content="#050505" />
    <meta name="color-scheme" content="dark" />
    <title>{title}</title>

    <!-- ─── Canonical & Hreflang ─────────────────────────── -->
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="en" href={canonicalURL} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL} />

    <!-- ─── Open Graph ────────────────────────────────────── -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Shreesh Kulkarni — Software Engineer" />
    <meta property="og:site_name" content="Shreesh Kulkarni" />
    <meta property="og:locale" content="en_US" />

    <!-- ─── Twitter / X Card ──────────────────────────────── -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@shreeshkulkarni" />
    <meta name="twitter:creator" content="@shreeshkulkarni" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content="Shreesh Kulkarni — Software Engineer" />

    <!-- ─── Favicons ──────────────────────────────────────── -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- ─── Analytics (Umami) ────────────────────────────── -->
    <!-- Sign up at https://umami.is, create a website, then replace YOUR_WEBSITE_ID below -->
    <script
      defer
      src="https://cloud.umami.is/script.js"
      data-website-id="1bdb92ff-0c53-46d0-8fc6-34231e99241f"
      is:inline
    ></script>

    <!-- ─── Additional head injections (JSON-LD etc.) ────── -->
    <slot name="head" />
  </head>
  <body class="bg-background text-white font-sans antialiased overflow-x-hidden">
    <slot />
  </body>
</html>
